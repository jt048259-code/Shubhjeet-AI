{
  "entities": {
    "User": {
      "title": "User",
      "description": "System users (Teachers and Admins)",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["teacher", "admin"] },
        "mobile": { "type": "string" },
        "classes": { "type": "array", "items": { "type": "string" } },
        "subjects": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "role"]
    },
    "AttendanceCode": {
      "title": "Attendance Code",
      "description": "6-digit unique code for attendance marking",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "createdBy": { "type": "string" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["code", "expiresAt"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Attendance records marked by teachers",
      "type": "object",
      "properties": {
        "teacherId": { "type": "string" },
        "teacherName": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["teacherId", "date"]
    },
    "LeaveApplication": {
      "title": "Leave Application",
      "description": "Leave requests submitted by teachers",
      "type": "object",
      "properties": {
        "teacherId": { "type": "string" },
        "teacherName": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "reason": { "type": "string" },
        "mobile": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["teacherId", "startDate", "endDate", "status"]
    },
    "TimeTable": {
      "title": "Time Table",
      "description": "School time table data",
      "type": "object",
      "properties": {
        "classLevel": { "type": "string" },
        "day": { "type": "string" },
        "schedule": { "type": "array" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/attendanceCodes/{codeId}": {
      "schema": "AttendanceCode",
      "description": "Active attendance codes"
    },
    "/attendance/{recordId}": {
      "schema": "Attendance",
      "description": "Attendance logs"
    },
    "/leaves/{leaveId}": {
      "schema": "LeaveApplication",
      "description": "Leave requests"
    },
    "/settings/school": {
      "description": "Global school settings like subjects and classes"
    },
    "/settings/timetable": {
      "description": "Full school timetable entries"
    },
    "/settings/subjectRequirements": {
      "description": "Staff requirements per subject"
    },
    "/arrangements/{arrangementId}": {
      "description": "Daily substitution arrangements"
    },
    "/studentAttendance/{attId}": {
      "description": "Daily student attendance summary"
    },
    "/holidays/{holidayId}": {
      "description": "School holidays"
    }
  }
}
