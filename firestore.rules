rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (getUserData().role == 'admin' || 
         request.auth.token.email == "jitendrakumart557@gmail.com");
    }
    
    function isTeacher() {
      return isAuthenticated() && getUserData().role == 'teacher';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin());
    }

    match /attendanceCodes/{codeId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /attendance/{recordId} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.teacherId);
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    match /leaves/{leaveId} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.teacherId);
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /timetable/{tableId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
